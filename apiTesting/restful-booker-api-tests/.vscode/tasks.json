{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run All API Tests",
      "type": "shell",
      "command": "dotnet test",
      "group": "test"
    },
    {
      "label": "Run Smoke Tests",
      "type": "shell",
      "command": "dotnet test --filter TestCategory=smoke",
      "group": "test"
    },
    {
      "label": "Show Playwright Report",
      "type": "shell",
      "command": "npx playwright show-report",
      "group": "test"
    }
  ]
}